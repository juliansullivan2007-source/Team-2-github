

// --- INPUTS (copper tape circuits) ---
int inputPins[5] = {2, 4, 6, 8, 12};

// --- SERVOS ---
#include <Servo.h>
Servo servos[4];
int servoPins[4] = {9, 10, 11, 12};

// --- PIEZO ---
int piezoPin = 8;

int currentStage = 0;  // tracks progress (0–4)

void playMelody() {
  tone(piezoPin, 262); // C
  delay(200);
  tone(piezoPin, 330); // E
  delay(200);
  tone(piezoPin, 392); // G
  delay(200);
  noTone(piezoPin);
}

void moveServoLoop(int index) {
  for (int pos = 0; pos <= 90; pos += 2) {
    servos[index].write(pos);
    delay(10);
  }
  for (int pos = 90; pos >= 0; pos -= 2) {
    servos[index].write(pos);
    delay(10);
  }
}

void setup() {
  // Inputs
  for (int i = 0; i < 5; i++) {
    pinMode(inputPins[i], INPUT_PULLUP);
  }

  // Servos
  for (int i = 0; i < 4; i++) {
    servos[i].attach(servoPins[i]);
  }

  pinMode(piezoPin, OUTPUT);
}

void loop() {

  // Read all inputs
  bool triggered[5];
  for (int i = 0; i < 5; i++) {
    triggered[i] = (digitalRead(inputPins[i]) == LOW);
  }

  // --- STAGE 0 → PIEZO ---
  if (currentStage == 0 && triggered[0]) {
    playMelody();
    currentStage = 1;
    delay(300); // debounce
  }

  // --- STAGE 1 → SERVO 0 ---
  if (currentStage == 1 && triggered[1]) {
    moveServoLoop(0);
    currentStage = 2;
    delay(300);
  }

  // --- STAGE 2 → SERVO 1 ---
  if (currentStage == 2 && triggered[2]) {
    moveServoLoop(1);
    currentStage = 3;
    delay(300);
  }

  // --- STAGE 3 → SERVO 2 ---
  if (currentStage == 3 && triggered[3]) {
    moveServoLoop(2);
    currentStage = 4;
    delay(300);
  }

  // --- STAGE 4 → SERVO 3 ---
  if (currentStage == 4 && triggered[4]) {
    moveServoLoop(3);
    currentStage = 0; // reset OR set to 5 if you want it to stop
    delay(300);
  }
}

